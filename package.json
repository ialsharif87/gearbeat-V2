{
  "name": "gearbeat-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run build",
    "ops:reset-self-test:dry-run": "npx tsx scripts/ops/reset-self-test-data.ts",
    "ops:reset-self-test:execute": "npx tsx scripts/ops/reset-self-test-data.ts --execute"
  },
  "dependencies": {
    "@sentry/nextjs": "latest",
    "@supabase/ssr": "0.6.1",
    "@supabase/supabase-js": "2.49.4",
    "@vercel/speed-insights": "^2.0.0",
    "chart.js": "4.4.3",
    "exceljs": "^4.4.0",
    "next": "^15.5.16",
    "react": "19.2.5",
    "react-chartjs-2": "5.2.0",
    "react-dom": "19.2.5",
    "resend": "^6.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "22.15.3",
    "@types/react": "19.1.3",
    "@types/react-dom": "19.1.3",
    "eslint": "9.25.1",
    "eslint-config-next": "^15.5.16",
    "typescript": "5.8.3"
  }
}
