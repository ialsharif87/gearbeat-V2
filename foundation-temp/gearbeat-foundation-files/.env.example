# GearBeat V2 environment variables
# Copy this file to .env.local and fill real values locally / in Vercel.
# Never commit .env.local.

# Supabase public client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase privileged server-only key
# Used only in protected admin/cron/server routes.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email provider
RESEND_API_KEY=
REVIEW_FROM_EMAIL=
REVIEW_EMAIL_FROM=

# Cron protection
# Must be at least 12 characters. Use a long random value in production.
CRON_SECRET=

# Optional future integrations
PAYMENT_GATEWAY=
PAYMENT_GATEWAY_SECRET_KEY=
WHATSAPP_BUSINESS_TOKEN=
SMS_PROVIDER_API_KEY=
